    "globals": "^17.6.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.33.1",
    "svelte-check": "^4.2.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.19"
